<Window x:Class="ExamPrep2024_Booking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExamPrep2024_Booking"
        mc:Ignorable="d"
        Title="RestaurantApp" Height="450" Width="800">
    <Grid>
        <Label Content="Booking Details" HorizontalAlignment="Left" Margin="46,48,0,0" VerticalAlignment="Top" FontSize="16"/>
        <DatePicker x:Name="date_BookDetails" HorizontalAlignment="Left" Margin="171,55,0,0" VerticalAlignment="Top"/>
        <ListBox x:Name="lbx_Bookings" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="46,93,383,88"/>
        <Label Content="Capacity" HorizontalAlignment="Left" Margin="46,374,0,0" VerticalAlignment="Top"/>
        <Label Content="Bookings" HorizontalAlignment="Left" Margin="142,374,0,0" VerticalAlignment="Top"/>
        <Label Content="Available" HorizontalAlignment="Left" Margin="239,374,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btn_Delete" Content="Delete Booking" HorizontalAlignment="Center" Margin="0,377,0,0" VerticalAlignment="Top" Height="21" Width="128"/>
        <TextBlock x:Name="tbl_Capacity" HorizontalAlignment="Left" Margin="106,381,0,0" TextWrapping="Wrap" VerticalAlignment="Top"/>
        <TextBlock x:Name="tbl_Booking" HorizontalAlignment="Left" Margin="206,381,0,0" TextWrapping="Wrap" VerticalAlignment="Top"/>
        <TextBlock x:Name="tbl_Available" HorizontalAlignment="Left" Margin="297,379,0,0" TextWrapping="Wrap" VerticalAlignment="Top"/>
        <Label Content="New Booking&#xD;&#xA;" HorizontalAlignment="Left" Margin="510,48,0,0" VerticalAlignment="Top" FontSize="16" Height="31"/>
        <DatePicker x:Name="date_NewBook" HorizontalAlignment="Left" Margin="511,84,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbx_CustomerNo" HorizontalAlignment="Left" Margin="510,137,0,0" TextWrapping="Wrap" Text="Number of Customers" VerticalAlignment="Top" Width="150"/>
        <TextBox x:Name="tbx_CustomerName" HorizontalAlignment="Left" Margin="511,180,0,0" TextWrapping="Wrap" Text="Customer Name" VerticalAlignment="Top" Width="150"/>
        <TextBox x:Name="tbx_ContactNo" HorizontalAlignment="Left" Margin="511,220,0,0" TextWrapping="Wrap" Text="Contact Number" VerticalAlignment="Top" Width="150"/>
        <Button x:Name="btn_Search" Content="Customer Search" HorizontalAlignment="Left" Margin="562,280,0,0" VerticalAlignment="Top" Height="25" Width="134"/>

    </Grid>
</Window>
